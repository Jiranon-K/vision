# Frontend (Next.js) — public env vars (exposed to the browser)

# Base URL of the backend API the frontend fetches from.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public site origin — used for SEO canonical URLs, Open Graph tags,
# sitemap.xml, and robots.txt. MUST be set to the real domain in production,
# otherwise all SEO metadata points at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend (server/) — see server/.env.example for the full list.
# MONGODB_URI=mongodb://localhost:27017/vision
# PORT=3001
# NODE_ENV=development
# JWT_SECRET=<generate-a-long-random-secret>
