{
  "name": "vision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n FE,BE -c cyan,magenta \"bun dev\" \"cd server && bun dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cleanup": "node scripts/remove-comments.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "{app,components,hooks,lib,types,scripts}/**/*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "{app,components,hooks,lib,types,scripts}/**/*.{js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "server/src/**/*.ts": [
      "bash -c 'cd server && tsc --noEmit'"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "animejs": "^4.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
